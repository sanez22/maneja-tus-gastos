# Variables de entorno para desarrollo local
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3000

# Conexión a PostgreSQL (desarrollo local con docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gastos_db
DB_USER=postgres
DB_PASS=postgres

# Para producción en Render.com, usar DATABASE_URL en lugar de las variables individuales
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

